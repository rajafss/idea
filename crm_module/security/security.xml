<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="module_category_crm" model="ir.module.category">
            <field name="name">CRM</field>
            <field name="sequence">3</field>
        </record>

     <record id="group_crm_user" model="res.groups">
            <field name="name">User: All Documents</field>
            <field name="category_id" ref="crm_module.module_category_crm"/>
        </record>

        <record id="group_crm_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="crm_module.module_category_crm"/>
            <field name="implied_ids" eval="[(4, ref('group_crm_user'))]"/>
        </record>

<!--        rule user can only edit prospection in new stage-->
        <record id="record_rule_no_edit" model="ir.rule">
            <field name="name">User can only edit in new stage </field>
            <field name="model_id" ref="model_crm_lead"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('is_draft', '=', False),('user_id', '=', user.id)]</field>
        </record>

        <record id="crm_lead_edit_own_rule" model="ir.rule">
                <field name="name">CRM Lead: Edit Own Only</field>
                <field name="model_id" ref="crm.model_crm_lead"/>
                <field name="groups" eval="[(4, ref('base.group_user'))]"/>
                <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
                <field name="perm_read" eval="1"/>
                <field name="perm_write" eval="1"/>
                <field name="perm_create" eval="1"/>
                <field name="perm_unlink" eval="0"/>
            </record>

        <record id="crm_lead_manager_full_access" model="ir.rule">
            <field name="name">CRM Manager Full Access</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="groups" eval="[(4, ref('crm_module.group_crm_manager'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

